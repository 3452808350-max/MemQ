# MemQ 环境变量配置示例
# 复制此文件为 .env 并填入真实的 API Key
# cp .env.example .env

# ============ 向量嵌入 API ============
# Dashscope (阿里云) API Key
# 获取方式：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ============ 评估模型 API（可选） ============
# Minimax API Key（用于基准测试评估）
# 获取方式：https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here

# ============ Kimi API（可选） ============
# Kimi Remote API Token
KIMI_API_TOKEN=your_kimi_api_token_here

# ============ 数据库配置（可选） ============
# LanceDB 路径（默认：~/.openclaw/workspace/lancedb）
# LANCEDB_PATH=/home/kyj/.openclaw/workspace/lancedb

# ============ 其他配置（可选） ============
# 日志级别：debug, info, warn, error
# LOG_LEVEL=info

# 是否启用缓存：true, false
# ENABLE_CACHE=true

# 缓存目录
# CACHE_DIR=./cache
