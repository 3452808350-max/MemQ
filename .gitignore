# OpenClaw .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Logs
*.log
logs/

# Local configuration
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Model cache (too large)
.cache/modelscope/

# Test results
test_results/
benchmark_results/

# Reports (keep templates, remove generated)
*_report.json
!*_template.json

# Node modules (too large for GitHub)
node_modules/

# Large binary files
*.node
