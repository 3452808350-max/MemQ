# DSS 环境变量配置示例
# 复制此文件为 .env 并填入真实的 API Key
# cp .env.example .env

# ============ 数据 API ============
# FRED (美国联邦储备经济数据)
# 获取方式：https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage (股票数据)
# 获取方式：https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Financial Modeling Prep
# 获取方式：https://site.financialmodelingprep.com/developer/docs/
FMP_API_KEY=your_fmp_api_key_here

# ============ LLM API ============
# DashScope (阿里云 - 用于情绪分析)
# 获取方式：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ============ 可选配置 ============
# 缓存目录
# DSS_CACHE_DIR=/home/kyj/.openclaw/workspace/data_cache

# 日志级别
# DSS_LOG_LEVEL=info